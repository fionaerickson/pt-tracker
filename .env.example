# MongoDB Atlas connection string (free tier is sufficient for a single user).
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"

# Database name used by the app.
MONGODB_DB="pt_tracker"

# Single-user build: the userId every document is scoped to until real auth is wired in.
# Replace with the auth provider's subject id once identity is owned elsewhere.
DEFAULT_USER_ID="local-user"
